# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here           # service_role, NOT anon key

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-key-min-32-chars-here
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# ── OTP ───────────────────────────────────────────────────────
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6

# ── SarvamAI ──────────────────────────────────────────────────
SARVAM_API_KEY=your-sarvam-api-key-here
SARVAM_BASE_URL=https://api.sarvam.ai/v1
SARVAM_MODEL=sarvam-m

# ── Admin ─────────────────────────────────────────────────────
ADMIN_SECRET=your-admin-secret-for-job-crud               # sent as X-Admin-Secret header

# ── App ───────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=DEBUG
CORS_ORIGINS=http://localhost:5173

# ── OpenAI ─────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_RETRIES=3
OPENAI_RPM_LIMIT=3

# ── Gemini ─────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_RETRIES=3
GEMINI_RPM_LIMIT=12

# ── Assessment Config ──────────────────────────
ASSESSMENT_MAX_QUESTIONS=11
ASSESSMENT_MIN_QUESTIONS=9
ASSESSMENT_MAX_RETAKES=2
ASSESSMENT_RETAKE_COOLDOWN_HOURS=24
