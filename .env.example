# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here           # service_role, NOT anon key

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-key-min-32-chars-here

# ── SarvamAI ──────────────────────────────────────────────────
SARVAM_API_KEY=your-sarvam-api-key-here

# ── Admin ─────────────────────────────────────────────────────
ADMIN_SECRET=your-admin-secret-for-job-crud               # sent as X-Admin-Secret header

# ── App ───────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=DEBUG
CORS_ORIGINS=http://localhost:5173

# ── OpenAI ─────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here

# ── Gemini ─────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Groq ─────────────────────────────────────
GROQ_API_KEY=your-key-here
